#!/usr/bin/env bash
# Set up environment variables.
# This is meant to work in bash and zsh.

. "$HOME/bin/shell_utils"

# locale
export LANG=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8
export LC_MESSAGES=en_US.UTF-8
export LC_COLLATE=C

paths=(
  /sbin
  /usr/sbin
  /bin
  /usr/bin
  /opt/X11/bin
  /usr/local/sbin
  /usr/local/bin
  /opt/local/bin
  /opt/local/sbin
  /opt/homebrew/bin
  /opt/homebrew/sbin
  /opt/homebrew/bin
  /opt/homebrew/opt/coreutils/libexec/gnubin
  /opt/homebrew/opt/texinfo/bin
  /opt/homebrew/opt/sqlite/bin
  /opt/homebrew/opt/openjdk/bin
  /opt/homebrew/opt/m4/bin
  /opt/homebrew/opt/llvm/bin
  /opt/homebrew/opt/ruby/bin
  /opt/homebrew/opt/python/libexec/bin
  /opt/homebrew/opt/gcc/bin
  $GOPATH/bin/usr/local/sbin
  $HOME/perl5/bin
  $HOME/.cargo/bin
  $GOPATH/bin/usr/local/sbin
  $HOME/bin
  $HOME/.emacs.d/bin
  $HOME/private/bin
)

pkg_config_paths=(
  /opt/homebrew/Library/Taps/homebrew/homebrew-core/Aliases/pkgconfig
  /opt/homebrew/Library/Homebrew/os/mac/pkgconfig
  /opt/homebrew/opt/ruby/lib/pkgconfig
  /opt/homebrew/lib/pkgconfig
  /usr/lib/pkgconfig
)

man_paths=(
  /opt/local/share/man
  /usr/local/share/man
  /usr/share/man
  /opt/homebrew/share/man
)

add_to_path PATH "${paths[@]}"
add_to_path PKG_CONFIG_PATH "${pkg_config_paths[@]}"
add_to_path MANPATH "${man_paths[@]}"

# Ensure we can find the Homebrew installed version of libgccjit for GCCEmacs.
# Hopefully this is future-proof past GCC-16, unlike the hard-coded example below.
# add_to_path LIBRARY_PATH "/opt/homebrew/Cellar/gcc/16.1.0/lib/gcc/current/gcc/aarch64-apple-darwin25/16"
hb_prefix=/opt/homebrew
[ -d "$hb_prefix" ] || hb_prefix=/usr/local

gcc_base="$hb_prefix/opt/gcc/lib/gcc/current"

for d in "$gcc_base"/gcc/*-apple-darwin*; do
  [ -f "$d/libemutls_w.a" ] && export LIBRARY_PATH="$d${LIBRARY_PATH:+:$LIBRARY_PATH}" && break
done

add_to_path PATH "$hb_prefix/opt/gcc/bin:$PATH"

# private
source_if "$HOME/private/private.sh"
